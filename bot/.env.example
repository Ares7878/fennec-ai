# ============================================
# 🦊 FENNEC AI — Configuration v2.0 (Optimisée)
# Copiez ce fichier en .env et remplissez vos clés
# ============================================

# --- COINBASE ADVANCED TRADE API ---
# Obtenez vos clés sur : https://advanced.coinbase.com/settings/api
COINBASE_API_KEY=your_api_key_here
COINBASE_API_SECRET=your_api_secret_here
# Optionnel : passphrase si votre clé en a une
COINBASE_PASSPHRASE=

# --- TELEGRAM BOT ---
# Créez votre bot via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Votre Chat ID (obtenez-le via @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id

# --- TRADING CONFIGURATION ---
# Mode : 'paper' (simulation) ou 'live' (réel)
TRADING_MODE=paper

# Paires de trading (séparées par des virgules)
# Recommandé : 2-3 paires maximum pour un capital < $1000
TRADING_PAIRS=BTC-USD,ETH-USD,SOL-USD

# Montant max par trade en USD
MAX_TRADE_AMOUNT_USD=54

# Pourcentage max du portefeuille par trade (0.1 = 10%)
MAX_POSITION_SIZE=0.1

# Stop-loss en % (0.03 = 3%) — v2.0: augmenté de 1% à 3%
DEFAULT_STOP_LOSS=0.03

# Take-profit en % (0.06 = 6%) — v2.0: augmenté de 2% à 6%
DEFAULT_TAKE_PROFIT=0.06

# Drawdown maximum avant arrêt d'urgence (0.15 = 15%)
MAX_DRAWDOWN=0.15

# Max trades par jour (toutes paires confondues)
MAX_DAILY_TRADES=6

# --- CAPITAL PAPER TRADING ---
PAPER_INITIAL_BALANCE=540

# --- STRATÉGIE ---
# Stratégie active : 'rsi', 'macd', 'ema_cross', 'bollinger', 'consensus' (recommandé)
ACTIVE_STRATEGY=consensus

# Intervalle d'analyse : '1m', '5m', '15m', '1h', '4h', '1d'
# v2.0: 1h recommandé (moins de bruit, signaux plus fiables)
CANDLE_INTERVAL=1h

# [CONSENSUS] Nombre minimum de signaux concordants pour trader (2, 3 ou 4)
MIN_CONSENSUS=3

# Force minimum du signal pour exécuter un trade (0.0 à 1.0)
# v2.0: augmenté de 0.55 à 0.65 pour filtrer les faux signaux
MIN_SIGNAL_STRENGTH=0.65

# Cooldown entre deux trades sur la même paire (en minutes)
# v2.0: augmenté de 60 à 120 minutes
TRADE_COOLDOWN_MINUTES=120

# [ATR] Multiplicateur ATR pour le Stop-Loss dynamique
# v2.0: augmenté de 1.5 à 2.0 (plus de marge pour la volatilité)
ATR_MULTIPLIER_SL=2.0

# [ATR] Multiplicateur ATR pour le Take-Profit dynamique
# v2.0: augmenté de 2.5 à 3.5 (meilleur R:R de 1:1.75)
ATR_MULTIPLIER_TP=3.5

# --- TRAILING STOP v2.0 ---
# % de gain avant d'activer le trailing stop (0.015 = 1.5%)
TRAILING_ACTIVATION_PCT=0.015

# % sous le high pour le trailing stop (0.01 = 1.0%)
TRAILING_DISTANCE_PCT=0.01

# % de gain pour activer le breakeven stop (0.01 = 1.0%)
BREAKEVEN_ACTIVATION_PCT=0.01

# --- FILTRE ADX ---
# ADX minimum pour considérer qu'il y a une tendance (< 20 = ranging)
MIN_ADX=20

# --- SERVEUR API (pour le dashboard) ---
API_PORT=3001
API_SECRET_KEY=change_this_to_a_random_secret_string

# --- BASE DE DONNÉES ---
DATABASE_PATH=./data/fennec.db

# --- LOGS ---
LOG_LEVEL=info
LOG_DIR=./logs

# --- RAPPORT QUOTIDIEN ---
# Heure d'envoi du rapport (format HH:MM)
DAILY_REPORT_TIME=20:00
